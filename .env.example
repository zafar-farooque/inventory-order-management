# ─────────────────────────────────────────────────────────────────────────────
# Root .env.example
# Copy this file to .env and fill in your real values.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── PostgreSQL credentials ────────────────────────────────────────────────────
# Used by the `db` service and to build DATABASE_URL for the backend.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=inventory_db


# ── Backend database connection string ────────────────────────────────────────
# Must match the credentials above.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
#
# • Local development (Postgres running on your machine):
#     DATABASE_URL=postgresql://postgres:changeme@localhost:5432/inventory_db
#
# • Inside Docker Compose (host = service name "db"):
#     DATABASE_URL=postgresql://postgres:changeme@db:5432/inventory_db

DATABASE_URL=postgresql://postgres:changeme@db:5432/inventory_db


# ── Frontend API base URL ─────────────────────────────────────────────────────
# Baked into the React bundle at build time via --build-arg.
# Must NOT have a trailing slash.
#
# • When running via Docker Compose on your local machine:
#     REACT_APP_API_URL=http://localhost:8000
#
# • Production (replace with your real domain):
#     REACT_APP_API_URL=https://api.yourdomain.com

REACT_APP_API_URL=http://localhost:8000
