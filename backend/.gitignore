# ─────────────────────────────────────────────────────────────────────────────
# Environment — NEVER commit secrets
# ─────────────────────────────────────────────────────────────────────────────
.env
*.env
!.env.example

# ─────────────────────────────────────────────────────────────────────────────
# Python cache & compiled files
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ─────────────────────────────────────────────────────────────────────────────
# Virtual environments
# ─────────────────────────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─────────────────────────────────────────────────────────────────────────────
# Distribution / packaging
# ─────────────────────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ─────────────────────────────────────────────────────────────────────────────
# Alembic
# ─────────────────────────────────────────────────────────────────────────────
# Keep alembic/versions/ tracked so migrations are version-controlled.
# Only ignore the compiled cache inside it.
alembic/versions/__pycache__/

# ─────────────────────────────────────────────────────────────────────────────
# Testing & coverage
# ─────────────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ─────────────────────────────────────────────────────────────────────────────
# Editor & OS artifacts
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
